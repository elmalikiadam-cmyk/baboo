{
  "expo": {
    "name": "Baboo",
    "slug": "baboo",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#f2efe8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.baboo.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f2efe8"
      },
      "package": "com.baboo.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-font"]
  }
}
