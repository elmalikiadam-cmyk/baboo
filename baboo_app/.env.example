# Baboo App — variables d'environnement (Expo utilise le préfixe EXPO_PUBLIC_)
# Copie ce fichier en .env.local et remplis les valeurs.

# Supabase (source des annonces, partagée avec l'app web)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox (optionnel — sans token, ListingMap affiche un fallback typographique)
EXPO_PUBLIC_MAPBOX_TOKEN=
