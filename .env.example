# ─────────────────────────────────────────────────────────────────
# Baboo web app — variables d'environnement
# Copie ce fichier en .env.local pour dev, configure sur Vercel pour prod.
# ─────────────────────────────────────────────────────────────────

# Database (Supabase Postgres)
# - DATABASE_URL : pooler (port 6543) — utilisée par l'app au runtime
# - DIRECT_URL   : session pooler (port 5432) — utilisée pour les migrations Prisma
DATABASE_URL=""
DIRECT_URL=""

# NextAuth (auth pas encore wirée — arrivera en phase B, variable prête)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Admin (laisser non défini en production sauf si tu veux exposer /admin)
# Si true, /admin devient accessible (sans auth pour l'instant, attention).
ADMIN_ENABLED=""

# Mapbox — optionnel, pour la carte sur la fiche détail
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Email transactionnel — optionnel, pour envoyer une confirmation de lead
RESEND_API_KEY=""

# Media — optionnel, pour l'upload d'images (pas encore actif)
CLOUDINARY_URL=""
