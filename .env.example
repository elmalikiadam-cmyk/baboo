# ─────────────────────────────────────────────────────────────────
# Baboo web app — variables d'environnement
# Copie ce fichier en .env.local pour dev, configure sur Vercel pour prod.
# ─────────────────────────────────────────────────────────────────

# Database (Supabase Postgres)
# - DATABASE_URL : pooler (port 6543) — utilisée par l'app au runtime
# - DIRECT_URL   : session pooler (port 5432) — utilisée pour les migrations Prisma
DATABASE_URL=""
DIRECT_URL=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# /admin n'est plus piloté par un flag global — l'accès dépend uniquement
# du rôle ADMIN sur le compte connecté (table UserRoleGrant).

# Upstash Redis (REST) — rate limiting anti-spam. Non bloquant : si les
# deux variables sont absentes, la protection tombe en no-op (fail-open).
# À provisionner avant mise en prod réelle.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Mapbox — optionnel, pour la carte sur la fiche détail
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Email transactionnel — optionnel, pour envoyer une confirmation de lead
RESEND_API_KEY=""

# Media — optionnel, pour l'upload d'images (pas encore actif)
CLOUDINARY_URL=""
