# ─────────────────────────────────────────────────────────────────
# Baboo web app — variables d'environnement
# Copie ce fichier en .env.local pour dev, configure sur Vercel pour prod.
# ─────────────────────────────────────────────────────────────────

# ───── Database (Supabase Postgres) ─────
# DATABASE_URL : pooler (port 6543) — runtime app
# DIRECT_URL   : session pooler (port 5432) — migrations Prisma
DATABASE_URL=""
DIRECT_URL=""

# ───── NextAuth ─────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ───── Storage Supabase ─────
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET=""          # public : photos d'annonces
SUPABASE_STORAGE_BUCKET_PRIVATE=""  # privé : KYC, baux, EDL, quittances

# ───── Upstash Redis (rate limit) ─────
# Optionnel — fallback no-op sans ces vars, la protection anti-spam reste off.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ───── Upstash QStash (cron + webhooks signés) ─────
# Optionnel — saved searches + rappels loyer + rent period monthly désactivés sans ça.
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ───── WhatsApp Business Cloud ─────
# Optionnel — templates `visit_booked`, `visit_reminder`, `rent_reminder`.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_APP_SECRET=""

# ───── Email transactionnel (Resend) ─────
# Optionnel — no-op si absent (console.log en dev).
RESEND_API_KEY=""
RESEND_FROM="Baboo <no-reply@baboo.ma>"

# ───── Mapbox ─────
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ───── Site URL (pour callbacks webhooks) ─────
NEXT_PUBLIC_SITE_URL="https://baboov3.vercel.app"

# ╔═══════════════════════════════════════════════════════════════╗
# ║ PAYMENT PROVIDERS (Phase 2 — packs visites Baboo)             ║
# ╚═══════════════════════════════════════════════════════════════╝

# Sélecteur gateway : "cmi" (carte marocaine) ou "youcan"
PAYMENT_GATEWAY=""

# CMI (Centre Monétique Interbancaire — standard Maroc)
CMI_MERCHANT_ID=""
CMI_STORE_KEY=""
CMI_API_URL=""  # test: https://testpayment.cmi.co.ma  prod: https://payment.cmi.co.ma
CMI_ENV="test"  # "test" | "prod"

# Fallback Stripe (cartes internationales / MRE)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Youcan Pay (alternative MA)
YOUCAN_PRIVATE_KEY=""

# Commission Baboo sur paiements encaissés (pourcentage, 0 = désactivé)
PAYMENT_FEE_PCT="0"

# ╔═══════════════════════════════════════════════════════════════╗
# ║ SIGNATURE ÉLECTRONIQUE                                         ║
# ╚═══════════════════════════════════════════════════════════════╝

# Yousign (sandbox puis prod). Fallback upload manuel PDF si non configuré.
YOUSIGN_API_KEY=""
YOUSIGN_WEBHOOK_SECRET=""
YOUSIGN_ENV="sandbox"  # "sandbox" | "prod"

# ╔═══════════════════════════════════════════════════════════════╗
# ║ NOTIFICATIONS OPS                                              ║
# ╚═══════════════════════════════════════════════════════════════╝

# Webhook Slack pour alerter l'équipe (agent manquant, lead promoteur…)
SLACK_OPS_WEBHOOK_URL=""

# ╔═══════════════════════════════════════════════════════════════╗
# ║ FEATURE FLAGS                                                  ║
# ║ Masquer certaines briques qui ne sont pas encore commerciales. ║
# ╚═══════════════════════════════════════════════════════════════╝

# Wallet encaissement loyers via PSP (Phase Q2 — désactivé pour V1).
ENABLE_RENT_WALLET="false"

# Signature électronique automatique des baux via Yousign
# (désactivée tant que compte Yousign pas provisionné).
ENABLE_ESIGNATURE="false"

# Garantie Loyers Impayés (GLI) — partenariat assurance à négocier.
ENABLE_GLI="false"
